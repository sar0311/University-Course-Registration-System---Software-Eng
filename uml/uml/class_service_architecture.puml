@startuml
title Class Diagram - Service Architecture (Developer View)

skinparam classAttributeIconSize 0

'========================
' Interfaces (optional but professional)
'========================
interface IAuthService {
  + verifySession(token: String): boolean
}

interface IEnrollmentService {
  + register(studentId: String, sectionId: String): Enrollment
  + drop(studentId: String, sectionId: String): Enrollment
}

interface IAdvisorService {
  + requestApproval(studentId: String, sectionId: String): String
  + approve(requestId: String): void
  + reject(requestId: String, reason: String): void
}

interface IPaymentService {
  + charge(studentId: String, amount: double): PaymentTransaction
}

interface IRefundService {
  + issueRefund(studentId: String, amount: double): RefundTransaction
}

interface ICourseCatalogService {
  + listCourses(filters: Map): List<CourseSection>
}

interface IEventBus {
  + publish(event: DomainEvent): void
}

interface IUniversityDB {
  + selectEnrollment(studentId: String, sectionId: String): Enrollment
  + insertEnrollment(enrollment: Enrollment): void
  + updateEnrollment(enrollment: Enrollment): void
  + getSection(sectionId: String): CourseSection
  + updateSection(section: CourseSection): void
}

'========================
' Concrete Services
'========================
class AuthService {
  + verifySession(token: String): boolean
}
class EnrollmentService {
  - auth: IAuthService
  - db: IUniversityDB
  - advisor: IAdvisorService
  - payment: IPaymentService
  - refund: IRefundService
  - bus: IEventBus
  + register(studentId: String, sectionId: String): Enrollment
  + drop(studentId: String, sectionId: String): Enrollment
  - validatePrerequisites(studentId: String, sectionId: String): boolean
  - checkSeatAvailability(sectionId: String): boolean
  - checkDropPolicy(studentId: String, sectionId: String): boolean
}
class AdvisorService {
  + requestApproval(studentId: String, sectionId: String): String
  + approve(requestId: String): void
  + reject(requestId: String, reason: String): void
}
class PaymentService {
  + charge(studentId: String, amount: double): PaymentTransaction
}
class RefundService {
  + issueRefund(studentId: String, amount: double): RefundTransaction
}
class CourseCatalogService {
  - db: IUniversityDB
  + listCourses(filters: Map): List<CourseSection>
}
class EventBus {
  + publish(event: DomainEvent): void
}
class UniversityDB {
  + selectEnrollment(studentId: String, sectionId: String): Enrollment
  + insertEnrollment(enrollment: Enrollment): void
  + updateEnrollment(enrollment: Enrollment): void
  + getSection(sectionId: String): CourseSection
  + updateSection(section: CourseSection): void
}

'========================
' Domain objects used by services (references)
'========================
class Enrollment
class CourseSection
class PaymentTransaction
class RefundTransaction

abstract class DomainEvent {
  - eventId: String
  - occurredAt: DateTime
}
class CourseRegisteredEvent
class CourseDroppedEvent

DomainEvent <|-- CourseRegisteredEvent
DomainEvent <|-- CourseDroppedEvent

'========================
' Implements (service -> interface)
'========================
IAuthService <|.. AuthService
IEnrollmentService <|.. EnrollmentService
IAdvisorService <|.. AdvisorService
IPaymentService <|.. PaymentService
IRefundService <|.. RefundService
ICourseCatalogService <|.. CourseCatalogService
IEventBus <|.. EventBus
IUniversityDB <|.. UniversityDB

'========================
' Dependencies / Associations
'========================
EnrollmentService --> IAuthService
EnrollmentService --> IUniversityDB
EnrollmentService --> IAdvisorService
EnrollmentService --> IPaymentService
EnrollmentService --> IRefundService
EnrollmentService --> IEventBus

CourseCatalogService --> IUniversityDB

EventBus --> DomainEvent

EnrollmentService ..> Enrollment : creates/updates
EnrollmentService ..> CourseSection : checks/updates
EnrollmentService ..> PaymentTransaction : creates
EnrollmentService ..> RefundTransaction : creates

EnrollmentService ..> CourseRegisteredEvent : publishes
EnrollmentService ..> CourseDroppedEvent : publishes

@enduml
